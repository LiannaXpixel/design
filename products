    <!-- PAYHIP POPUP -->
    <div class="checkout-overlay" id="checkoutOverlay">
        <div class="checkout-popup">
            <button class="close-popup" onclick="closeCheckout()">×</button>
            <iframe id="checkoutFrame" src="" title="Checkout Frame"></iframe>
        </div>
