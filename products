    <script>
        function openCheckout(url) {
            document.getElementById('checkoutOverlay').style.display = 'flex';
            document.getElementById('checkoutFrame').src = url;
            document.body.style.overflow = 'hidden';
        }

        function closeCheckout() {
            document.getElementById('checkoutOverlay').style.display = 'none';
            document.getElementById('checkoutFrame').src = ''; /* Clear src */
            document.body.style.overflow = 'auto';
        }

        function openImage(src, altText) {
            const popupImage = document.getElementById('popupImage');
            popupImage.src = src;
            popupImage.alt = altText;
            popupImage.classList.remove('loaded'); /* Reset for fade-in */
            document.getElementById('imagePopup').style.display = 'flex';
            document.body.style.overflow = 'hidden';

            popupImage.onload = () => {
                popupImage.classList.add('loaded');
            };
            if (popupImage.complete) {
                 popupImage.classList.add('loaded');
            }
        }

        function closeImage() {
            document.getElementById('imagePopup').style.display = 'none';
            document.getElementById('popupImage').src = ''; /* Clear src */
            document.getElementById('popupImage').alt = ''; /* Clear alt text */
            document.body.style.overflow = 'auto';
        }

        window.addEventListener('click', function (e) {
            const overlay = document.getElementById('checkoutOverlay');
            const imagePopup = document.getElementById('imagePopup');

            if (e.target === overlay) {
                closeCheckout();
            }

            if (e.target === imagePopup) {
                closeImage();
            }
        });

        /* Function to handle image switching and apply zoom listener */
        function updateGalleryImage(wrapperElement, imgElement) {
            const img = imgElement;
            img.style.opacity = '0'; /* Start hidden for fade effect */

            /* Set the onclick handler directly on the image */
            img.onclick = () => openImage(img.src, img.alt);

            img.onload = () => {
                img.classList.add('loaded');
                img.style.opacity = '1'; /* Make visible after loaded */
            };
            if (img.complete) { /* For cached images */
                img.classList.add('loaded');
                img.style.opacity = '1';
            }
        }

        function changeImage(direction, galleryId) {
            const gallery = document.getElementById(galleryId);
            const imagesContainer = gallery.querySelector('.card-gallery-images');
            const imageWrappers = Array.from(imagesContainer.querySelectorAll('.card-gallery-image-wrapper'));

            let currentIndex = -1;
            for (let i = 0; i < imageWrappers.length; i++) {
                if (imageWrappers[i].style.display === 'block') {
                    currentIndex = i;
                    break;
                }
            }
            if (currentIndex === -1) currentIndex = 0; /* Default to first image if none active */

            let newIndex = currentIndex + direction;

            if (newIndex < 0) {
                newIndex = imageWrappers.length - 1;
            } else if (newIndex >= imageWrappers.length) {
                newIndex = 0;
            }

            imageWrappers.forEach((wrapper, index) => {
                if (index === newIndex) {
                    wrapper.style.display = 'block';
                    const img = wrapper.querySelector('img');
                    if (img) {
                        updateGalleryImage(wrapper, img); /* Apply updates and listener */
                    }
                } else {
                    wrapper.style.display = 'none';
                }
            });
        }

        /* Initialize the gallery display and set up onclick for first image */
        document.addEventListener('DOMContentLoaded', () => {
            const galleries = document.querySelectorAll('.card-gallery');
            galleries.forEach(gallery => {
                const imageWrappers = gallery.querySelectorAll('.card-gallery-image-wrapper');
                imageWrappers.forEach((wrapper, index) => {
                    if (index === 0) {
                        wrapper.style.display = 'block';
                        const img = wrapper.querySelector('img');
                        if (img) {
                            updateGalleryImage(wrapper, img); /* Initialize for the first image */
                        }
                    } else {
                        wrapper.style.display = 'none';
                    }
                });
            });

            /* Ensure popup image is handled */
            const popupImage = document.getElementById('popupImage');
            if (popupImage && popupImage.src) {
                popupImage.onload = () => {
                    popupImage.classList.add('loaded');
                };
                if (popupImage.complete) {
                    popupImage.classList.add('loaded');
                }
            }
        });
    </script>

