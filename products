<style>
    /* CSS Variables */
    :root {
        --primary-color: #ff0077;
        --secondary-color: #ff3399;
        --dark-background: #0b0b0b;
        --card-background: #151515;
        --border-color: #252525;
        --text-color-primary: white;
        --text-color-secondary: #e5e5e5;
        --text-color-muted: #8e8e8e;
        --text-color-highlight: #bdbdbd;
        --font-family: Arial, sans-serif;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: var(--font-family);
    }

    html,
    body {
        background: var(--dark-background);
        color: var(--text-color-primary);
        overflow-x: hidden;
    }

    body {
        min-height: 100vh;
    }

    /* HERO BANNER */
    .hero-banner {
        position: relative;
        width: 100%;
        height: 620px;
        overflow: hidden;
    }

    .hero-banner img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        object-position: center;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: none;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 20px;
    }

    .hero-content h1 {
        font-size: 64px;
        margin-bottom: 18px;
        text-shadow: 0 0 25px rgba(0, 0, 0, .6);
    }

    .hero-content p {
        font-size: 20px;
        max-width: 700px;
        color: var(--text-color-secondary);
        line-height: 1.6;
    }

    /* HERO TEXT SECTION */
    .hero-text-section {
        text-align: center;
        padding: 55px 20px 25px;
        background: var(--dark-background);
    }

    .hero-text-section h1 {
        font-size: 38px;
        margin-bottom: 16px;
        color: #b8a79d;
        font-weight: 500;
        letter-spacing: 1px;
        text-align: center;
    }

    .hero-text-section p {
        font-size: 17px;
        max-width: 760px;
        margin: auto;
        color: var(--text-color-muted);
        line-height: 1.8;
        text-align: center;
    }

    /* PRODUCTS */
    .products {
        width: 100%;
        max-width: 1500px;
        margin: auto;
        padding: 70px 35px;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 35px;
    }

    .card {
        background: var(--card-background);
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid var(--border-color);
        transition: .35s;
        position: relative;
        display: flex;
        flex-direction: column;
    }

    .card:hover {
        transform: translateY(-8px);
        border-color: var(--primary-color);
        box-shadow: 0 0 40px rgba(255, 0, 119, .18);
    }

    /* Image Gallery within Card */
    .card-gallery {
        position: relative;
        overflow: hidden;
        cursor: pointer; /* Indicates it's clickable */
        display: flex;
        justify-content: center; /* Center content horizontally */
        align-items: center; /* Center content vertically */
        width: 100%;
        height: 420px;
        background-color: var(--border-color); /* Fallback background */
    }

    .card-gallery-images {
        display: flex;
        transition: transform 0.5s ease-in-out;
        width: 100%;
        height: 100%;
        position: relative;
    }

    .card-gallery-image-wrapper {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: none;
        justify-content: center;
        align-items: center;
    }

    .card-gallery img {
        max-width: 100%;
        max-height: 100%;
        object-fit: cover;
        display: block;
        opacity: 0;
        transition: opacity 0.5s ease-in-out;
        border-radius: inherit;
    }

    .card-gallery img.loaded {
        opacity: 1;
    }

    .card-gallery-nav {
        position: absolute;
        top: 50%;
        width: 100%;
        display: flex;
        justify-content: space-between;
        transform: translateY(-50%);
        z-index: 10;
        pointer-events: none;
    }

    .card-gallery-nav button {
        background: rgba(0, 0, 0, .6);
        color: var(--text-color-primary);
        border: none;
        padding: 10px;
        cursor: pointer;
        font-size: 20px;
        border-radius: 50%;
        margin: 0 15px;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: auto;
        transition: background 0.3s ease;
    }

    .card-gallery-nav button:hover {
        background: var(--primary-color);
    }

    .zoom-label {
        position: absolute;
        bottom: 15px;
        right: 15px;
        background: rgba(0, 0, 0, .6);
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 14px;
        backdrop-filter: blur(5px);
        z-index: 5;
        opacity: 1; /* Initially hidden */
        transition: opacity 0.3s ease-in-out;
    }

    /* Show zoom label when an image is displayed */
    .card-gallery-image-wrapper:not([style*="display: none"]) .zoom-label {
        opacity: 1;
    }

    .card-content {
        padding: 24px;
        flex-grow: 1;
    }

    .card-content h2 {
        font-size: 26px;
        margin: 0 0 12px 0; /* Added margin reset for clarity */
    }

    .description {
        color: var(--text-color-highlight);
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .price {
        color: var(--primary-color);
        font-size: 30px;
        font-weight: bold;
        margin-bottom: 22px;
    }

    .buy-btn {
        display: inline-block;
        background: var(--primary-color);
        color: var(--text-color-primary);
        text-decoration: none;
        padding: 14px 24px;
        border-radius: 14px;
        font-weight: bold;
        transition: .3s;
        font-size: 16px;
        margin-top: auto;
        border: none;
        cursor: pointer;
    }

    .buy-btn:hover {
        background: var(--secondary-color);
        transform: translateY(-2px);
    }

    /* IMAGE POPUP */
    .image-popup {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .88);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 999999;
        backdrop-filter: blur(8px);
    }

    .image-popup img {
        width: 90%;
        max-width: 1400px;
        max-height: 90vh;
        object-fit: contain;
        border-radius: 18px;
        box-shadow: 0 0 50px rgba(255, 255, 255, .08);
        opacity: 0;
        transition: opacity 0.5s ease-in-out;
    }

    .image-popup img.loaded {
        opacity: 1;
    }

    .close-image {
        position: absolute;
        top: 20px;
        right: 25px;
        width: 50px;
        height: 50px;
        border: none;
        border-radius: 50%;
        background: var(--primary-color);
        color: var(--text-color-primary);
        font-size: 30px;
        cursor: pointer;
        z-index: 1000000;
        transition: background 0.3s ease;
    }

    .close-image:hover {
        background: var(--secondary-color);
    }

    /* PAYHIP POPUP */
    .checkout-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.82);
        backdrop-filter: blur(8px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 999999;
    }

    .checkout-popup {
        position: relative;
        width: 92%;
        max-width: 1000px;
        height: 92vh;
        background: #111;
        border: 1px solid var(--primary-color);
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 0 45px rgba(255, 0, 119, .35);
    }

    .checkout-popup iframe {
        width: 100%;
        height: 100%;
        border: none;
        background: white;
    }

    .close-popup {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 44px;
        height: 44px;
        border: none;
        border-radius: 50%;
        background: var(--primary-color);
        color: var(--text-color-primary);
        font-size: 24px;
        cursor: pointer;
        z-index: 10;
        transition: background 0.3s ease;
    }

    .close-popup:hover {
        background: var(--secondary-color);
    }

    /* MENU */
    .main-menu {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 18px;
        padding: 22px 15px;
        background: #111;
        border-top: 1px solid #1d1d1d;
        border-bottom: 1px solid #1d1d1d;
        flex-wrap: wrap;
    }

    .main-menu a {
        color: var(--text-color-primary);
        text-decoration: none;
        padding: 12px 22px;
        border-radius: 14px;
        background: #171717;
        border: 1px solid var(--border-color);
        transition: .3s;
        font-weight: bold;
    }

    .main-menu a:hover {
        background: var(--primary-color);
        border-color: var(--primary-color);
        transform: translateY(-2px);
    }

    /* PAGINATION */
    .pagination {
